FROM python:3.10-slim

WORKDIR /app

# Prevent Python buffering and create a writable HF cache location
ENV PYTHONUNBUFFERED=1 \
    HF_HOME=/data/.huggingface \
    TRANSFORMERS_CACHE=/data/.huggingface \
    XDG_CACHE_HOME=/data/.cache

RUN mkdir -p /data/.huggingface /data/.cache

# System packages commonly needed by pandas / sklearn / xgboost / transformers
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

EXPOSE 7860

CMD ["uvicorn", "app.app:app", "--host", "0.0.0.0", "--port", "7860"]