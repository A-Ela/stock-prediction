PORT=5000
MONGO_URI=mongodb://localhost:27017/stock-prediction
JWT_SECRET=change-me

AI_SERVICE_URL=http://localhost:8000/predict
AI_SERVICE_TIMEOUT_MS=180000

# --- Local SMTP (Mailpit) — run: npm run smtp:up from project root ---
# Web inbox: http://localhost:8025
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_FROM=StockSight <alerts@stocksight.local>
SMTP_WEB_URL=http://localhost:8025

# --- Production SMTP (Gmail example) — comment out Mailpit block above ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
#
# Option A: App password (simpler)
# SMTP_PASS=your-app-password
# SMTP_FROM=StockSight <your-email@gmail.com>
#
# Option B: OAuth2 (recommended for production)
# To use OAuth2, create credentials in Google Cloud Console for an OAuth client
# and obtain a refresh token for the sending account. Set these values and
# comment out the `SMTP_PASS` line above.
# GMAIL_CLIENT_ID=your-google-client-id
# GMAIL_CLIENT_SECRET=your-google-client-secret
# GMAIL_REFRESH_TOKEN=your-refresh-token

THRESHOLD_MONITOR_CRON=*/5 * * * *
DAILY_DIGEST_CRON=0 8 * * *
DIGEST_TIMEZONE=America/New_York
